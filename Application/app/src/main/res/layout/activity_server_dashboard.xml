<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="#F5F7FA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- هدر با لوگو -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="همسپار"
                        android:fontFamily="@font/yekan"
                        android:textColor="#1F2937"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="اشتراک‌گذاری فایل بدون اینترنت"
                        android:fontFamily="@font/yekan"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtUserInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tv_user_bg"
                    android:padding="8dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="کاربر"
                    android:fontFamily="@font/yekan"
                    android:textColor="#ffffff"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>


            <!-- ==================== کارت QR کد (انتقال به بالا) ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 اسکن QR برای اتصال سریع"
                        android:fontFamily="@font/yekan"
                        android:textColor="#1F2937"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/yekan"
                        android:text="دستگاه دیگر به هات اسپات یا وای فای مشترک با شما وصل شود و این کیو آر کد را اسکن کند"
                        android:textColor="#6B7280"
                        android:gravity="center_horizontal"
                        android:textSize="13dp" />


                    <ImageView
                        android:id="@+id/imgQrCode"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_marginTop="8dp"
                        android:background="#F3F4F6"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:layout_marginTop="15dp"
                        android:fontFamily="@font/yekan"
                        android:text="اگر نمیتواند اسکن کند این لینک را در مرورگر باز کند"
                        android:textColor="#6B7280"
                        android:textSize="12dp" />
                    <TextView
                        android:id="@+id/txtServerUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:background="#F3F4F6"
                        android:fontFamily="monospace"
                        android:padding="10dp"
                        android:text="http://..."
                        android:textColor="#3B82F6"
                        android:textSize="14dp"
                        android:textIsSelectable="true" />

                    <Button
                        android:id="@+id/btnCopyUrl"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#4F46E5"
                        android:text="📋 کپی لینک"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- کارت آپلود فایل -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📤 ارسال فایل"
                            android:fontFamily="@font/yekan"
                            android:textColor="#1F2937"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtPremiumBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/tv_premium_bg"
                            android:padding="4dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="نسخه ویژه"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/uploadArea"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/upload_area_border"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📂"
                            android:textSize="48sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="برای به اشتراک گذاری کلیک کنید"
                            android:fontFamily="@font/yekan"
                            android:textColor="#334155"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="فایل خود را انتخاب کنید"
                            android:fontFamily="@font/yekan"
                            android:textColor="#94A3B8"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/txtUploadProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/txtLimitWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="#FEF2F2"
                        android:padding="10dp"
                        android:text="⚠️ کاربران عادی حداکثر 500 مگابایت آپلود می‌کنند"
                        android:textColor="#DC2626"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/txtStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="#F1F5F9"
                        android:gravity="center"
                        android:padding="10dp"
                        android:textDirection="rtl"
                        android:text="📊 0 فایل | حجم کل: 0 B"
                        android:textColor="#475569"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- کارت فایل‌های سرور -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗂️ فایل‌های روی سرور"
                        android:fontFamily="@font/yekan"
                        android:textColor="#1F2937"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="برای باز کردن فایل کلیک کنید"
                        android:fontFamily="@font/yekan"
                        android:textColor="#6B7280"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:id="@+id/layoutFilesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnOpenFolder"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:backgroundTint="#3B82F6"
                            android:text="📁 باز کردن پوشه"
                            android:fontFamily="@font/yekan"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnDeleteAll"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="#EF4444"
                            android:text="🗑️ حذف همه"
                            android:fontFamily="@font/yekan"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- کارت کاربران متصل -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥 کاربران متصل"
                        android:fontFamily="@font/yekan"
                        android:textColor="#1F2937"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtClientsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#10B981"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerClients"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- کارت وضعیت سرور -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="وضعیت سرور"
                        android:fontFamily="@font/yekan"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtServerStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="فعال"
                            android:fontFamily="@font/yekan"
                            android:textColor="#10B981"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtServerUrlShort"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#F3F4F6"
                            android:fontFamily="monospace"
                            android:padding="6dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="http://..."
                            android:textColor="#3B82F6"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtLocalIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="#F3F4F6"
                        android:fontFamily="monospace"
                        android:padding="10dp"
                        android:text="192.168.1.1:8080"
                        android:textColor="#F59E0B"
                        android:textSize="13sp"
                        android:textIsSelectable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== آموزش گام‌به‌گام (بالا برای کاربر جدید) ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#10B981"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="🚀 چگونه از همسپار استفاده کنم؟"
                        android:fontFamily="@font/yekan"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="8dp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/yekan"
                        android:textSize="15dp"
                        android:gravity="right"
                        android:layoutDirection="rtl"
                        android:textDirection="rtl"
                        android:text="1️⃣ هات‌اسپات گوشی خود را روشن کنید\n2️⃣ دستگاه دیگر (گوشی یا کامپیوتر) را به هات‌اسپات وصل کنید\n3️⃣ QR کد را با دستگاه دیگر اسکن کنید یا لینک را در مرورگر وارد کنید\n4️⃣ فایل خود را آپلود یا دانلود کنید\n💡 نکته: هر دو دستگاه باید به یک شبکه وای‌فای متصل باشند و در انتخاب آی پی هنگام ایجاد سرور دقت کنید و اگر نشد آی پی دیگر را انتخاب کنید" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
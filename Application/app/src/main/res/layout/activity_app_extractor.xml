<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <!-- هدر مدرن -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:titleTextColor="#1F2937"
        app:title="استخراج APK"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#1F2937" />

    <!-- تب‌های برنامه‌های کاربر و سیستمی -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabIndicatorColor="#10B981"
        app:tabSelectedTextColor="#10B981"
        app:tabTextColor="#6B7280"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 کاربر" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ سیستمی" />

    </com.google.android.material.tabs.TabLayout>

    <!-- نوار جستجو -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                android:layout_marginStart="12dp"
                android:tint="#9CA3AF" />

            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="جستجوی برنامه..."
                android:inputType="text"
                android:padding="12dp"
                android:textSize="14sp"
                android:fontFamily="@font/yekan" />

            <ImageView
                android:id="@+id/btnClearSearch"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:padding="8dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                app:tint="#9CA3AF" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- آمار و دکمه‌های انتخاب -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtSelectedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 انتخاب شده"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:fontFamily="@font/yekan" />

        <TextView
            android:id="@+id/btnSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="انتخاب همه"
            android:textSize="12sp"
            android:textColor="#10B981"
            android:background="@drawable/bg_chip_light"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnDeselectAll"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:layout_marginStart="8dp"
            android:text="لغو"
            android:textSize="12sp"
            android:textColor="#EF4444"
            android:background="@drawable/bg_chip_light"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- لیست برنامه‌ها -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:paddingTop="4dp" />

    <!-- لودینگ -->
    <FrameLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:background="#F8FAFC">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="#10B981" />

    </FrameLayout>

    <!-- دکمه استخراج ثابت در پایین -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExtract"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:backgroundTint="#10B981"
        android:text="📦 استخراج فایل APK"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/yekan"
        android:enabled="false"
        app:cornerRadius="28dp"
        app:icon="@drawable/ic_apk"
        app:iconTint="#FFFFFF"
        app:iconGravity="textStart" />

    <!-- ProgressBar خطی برای پیشرفت -->
    <LinearLayout
        android:id="@+id/progressLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:background="#FFFFFF"
        app:cardCornerRadius="0dp">

        <TextView
            android:id="@+id/txtProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="در حال استخراج..."
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:fontFamily="@font/yekan"
            android:layout_marginBottom="4dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progressTint="#10B981" />
    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layoutDirection="rtl"
    android:background="@drawable/dialog_bg_rounded">

    <!-- عنوان -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📸 راهنمای تصویری پیدا کردن آی‌پی"
            android:textColor="#1F2937"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/yekan" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مرحله 1 از 3"
            android:textColor="#6366F1"
            android:textSize="11sp"
            android:background="#E0E7FF"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center"
            app:cornerRadius="12dp" />

    </LinearLayout>

    <!-- ViewPager با ارتفاع ثابت -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerGuide"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginBottom="16dp" />

    <!-- نشانگر صفحه (Page Indicator) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        app:tabIndicatorHeight="0dp"
        app:tabGravity="center"
        app:tabSelectedTextColor="#6366F1" />

    <!-- دکمه‌های navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#9CA3AF"
            android:text="◀ قبلی"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:visibility="gone"
            app:cornerRadius="22dp" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#6366F1"
            android:text="بعدی ▶"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            app:cornerRadius="22dp" />

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true"
    android:layoutDirection="rtl">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/llFooterButtons"
        android:background="#F5F7FA"
        android:layoutDirection="rtl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header with Logo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="همسپار"
                        android:fontFamily="@font/yekan"
                        android:textColor="#1F2937"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="اشتراک‌گذاری فایل بدون اینترنت"
                        android:fontFamily="@font/yekan"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:id="@+id/indicatorStatus"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/indicator_off" />
            </LinearLayout>

            <!-- آموزش سریع - طراحی مدرن -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- هدر با گرادیان -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradient_header_bg"
                        android:padding="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🚀 راهنمای استفاده از همسپار"
                            android:fontFamily="@font/yekan"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_guide"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="آسان"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- مراحل به صورت قدم‌به‌قدم -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- مرحله 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/circle_step"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="#6366F1"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="روشن کردن هات‌اسپات"
                                    android:textColor="#1F2937"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="هات‌اسپات گوشی را روشن کن"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📡"
                                android:textSize="20sp" />

                        </LinearLayout>

                        <!-- مرحله 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/circle_step"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="#6366F1"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="اتصال دستگاه دیگر"
                                    android:textColor="#1F2937"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="دستگاه دیگر را به وای فای هات‌اسپات خود وصل کن"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔗"
                                android:textSize="20sp" />

                        </LinearLayout>

                        <!-- مرحله 3 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/circle_step"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="#6366F1"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="شروع سرور"
                                    android:textColor="#1F2937"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="روی دکمه «شروع سرور» بزن"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚀"
                                android:textSize="20sp" />

                        </LinearLayout>

                        <!-- مرحله 4 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/circle_step"
                                android:gravity="center"
                                android:text="4"
                                android:textColor="#6366F1"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="اتصال از طریق QR"
                                    android:textColor="#1F2937"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" با دستگاه دیگر کد را اسکن کن یا لینک را در مرورگر وارد کن"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📱"
                                android:textSize="20sp" />

                        </LinearLayout>

                        <!-- مرحله 5 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/circle_step"
                                android:gravity="center"
                                android:text="5"
                                android:textColor="#6366F1"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="اشتراک‌گذاری فایل"
                                    android:textColor="#1F2937"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="فایل را آپلود یا دانلود کن"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📤"
                                android:textSize="20sp" />

                        </LinearLayout>

                        <!-- نکات اضافی -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="#F0FDF4"
                            android:padding="12dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:radius="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💡 نکات مهم"
                                android:textColor="#059669"
                                android:textSize="12dp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✓ هر دو دستگاه به یک شبکه وصل باشند\n✓ چند دستگاه می‌توانند همزمان متصل شوند\n✓ فایل بدون اینترنت منتقل می‌شود"
                                android:textColor="#374151"
                                android:textSize="11dp"
                                android:lineSpacingExtra="4dp" />

                        </LinearLayout>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="راهنمای ویدیویی"
                            android:textSize="12dp"
                            android:fontFamily="@font/yekan"
                            android:gravity="center_horizontal"
                            android:layout_marginTop="10dp"
                            android:textColor="#6559ff"
                            android:textStyle="bold"
                            android:id="@+id/tvVideoGuid"/>


                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- کارت وضعیت سرور -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="وضعیت سرور"
                        android:fontFamily="@font/yekan"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtServerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="خاموش"
                        android:textColor="#EF4444"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <!-- نمایش وضعیت ذخیره‌سازی -->
                    <TextView
                        android:id="@+id/txtStorageMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:padding="8dp"
                        android:background="#F3F4F6"
                        android:textColor="#374151"
                        android:textSize="12dp"
                        android:fontFamily="@font/yekan"
                        android:gravity="center"
                        android:visibility="gone"
                        android:text="📁 حالت ذخیره‌سازی: در حال بررسی..." />

                    <Button
                        android:id="@+id/btnStartStop"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="#10B981"
                        android:text="شروع سرور"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="30dp" />

                    <CheckBox
                        android:id="@+id/chkProtectDelete"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="عدم اجازه حذف فایل توسط طرف مقابل"
                        android:textColor="#374151" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- کارت اطلاعات شبکه و کاربران -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="🌐 لینک دسترسی"
                        android:fontFamily="@font/yekan"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtServerUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="#F3F4F6"
                        android:fontFamily="monospace"
                        android:padding="12dp"
                        android:text="---"
                        android:textColor="#3B82F6"
                        android:textIsSelectable="true"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnCopyUrl"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginBottom="16dp"
                        android:backgroundTint="#E5E7EB"
                        android:enabled="false"
                        android:text="📋 کپی لینک"
                        android:textColor="#374151"
                        android:textStyle="bold"
                        app:cornerRadius="22dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="#E5E7EB" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="📡 آی‌پی محلی"
                        android:fontFamily="@font/yekan"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtLocalIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="---"
                        android:textColor="#F59E0B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="#E5E7EB" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥 کاربران آنلاین"
                        android:fontFamily="@font/yekan"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtClientsCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#10B981"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnOpenBrowser"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#8B5CF6"
                        android:enabled="false"
                        android:text="🌐 باز کردن در مرورگر"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:cornerRadius="30dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- کارت QR کد -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="اسکن QR برای اتصال سریع"
                        android:fontFamily="@font/yekan"
                        android:textColor="#1F2937"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imgQrCode"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:background="#F3F4F6"
                        android:padding="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="دستگاه دیگر این کد را اسکن کند"
                        android:fontFamily="@font/yekan"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- فوتر با دکمه‌های پایین -->
    <LinearLayout
        android:id="@+id/llFooterButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="10dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="4dp"
            android:paddingBottom="16dp">

            <!-- دکمه پنل فایل -->
            <LinearLayout
                android:id="@+id/browserButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_button_bg_browser">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_browser"
                        app:tint="#FFFFFF" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/yekan"
                    android:text="پنل فایل"
                    android:textColor="#8B5CF6"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- دکمه نسخه پرو -->
            <LinearLayout
                android:id="@+id/premiumButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_button_bg_favorite">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_crown"
                        app:tint="#FFFFFF" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/yekan"
                    android:text="نسخه پرو"
                    android:textColor="#E74C3C"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- دکمه نظر دادن -->
            <LinearLayout
                android:id="@+id/commentButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_button_bg_mastered">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_comment"
                        app:tint="#FFFFFF" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/yekan"
                    android:text="نظر دادن"
                    android:textColor="#27AE60"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- دکمه سایر اپ‌ها -->
            <LinearLayout
                android:id="@+id/otherAppsButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
